DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=60

# LangGraph Agent
AGENT_LLM_TEMPERATURE=0.2
AGENT_MAX_TOOL_LOOPS=8
AGENT_CHECKPOINT_ENABLED=true
AGENT_CHECKPOINT_POOL_MAX=10
# 外部 MCP server（JSON，空则不加载）。示例：
# AGENT_MCP_SERVERS={"weather":{"url":"http://mcp:8000/mcp","transport":"streamable_http"}}
AGENT_MCP_SERVERS={}

# 车联网 / 报警阈值
ALERT_SPEED_LIMIT_KMH=90
ALERT_SPEED_HIGH_MARGIN=20
ALERT_TEMP_MIN_C=-18
ALERT_TEMP_MAX_C=8
ALERT_FUEL_LOW_PCT=15
ALERT_DEDUP_MINUTES=15
DEVICE_OFFLINE_MINUTES=10
AMAP_KEY=
