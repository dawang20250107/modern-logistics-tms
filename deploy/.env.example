# ── Django ─────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-only-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_FORMAT=json

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=tms
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms_dev_pwd
DATABASE_URL=postgres://tms:tms_dev_pwd@db:5432/tms
DB_CONN_MAX_AGE=60

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ────────────────────────────────────────────────
JWT_ACCESS_MIN=30
JWT_REFRESH_DAYS=7

# ── DeepSeek (AI) ──────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=60

# ── LangGraph Agent ────────────────────────────────────
AGENT_LLM_TEMPERATURE=0.2
AGENT_MAX_TOOL_LOOPS=8
AGENT_CHECKPOINT_ENABLED=true
AGENT_CHECKPOINT_POOL_MAX=10
# 外部 MCP server（JSON，空则不加载）
AGENT_MCP_SERVERS={}

# ── 车联网 / 报警 ──────────────────────────────────────
ALERT_SPEED_LIMIT_KMH=90
DEVICE_OFFLINE_MINUTES=10
AMAP_KEY=
